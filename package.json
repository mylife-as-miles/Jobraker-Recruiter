{
  "name": "jobraker-recruiter-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web",
    "dev:desktop": "npm run dev --prefix desktop/apps/x",
    "build:desktop": "npm run deps --prefix desktop/apps/x && npm run build:renderer --prefix desktop/apps/x"
  },
  "workspaces": [
    "web"
  ],
  "overrides": {
    "@tiptap/core": "3.22.4",
    "@tiptap/extension-bubble-menu": "3.22.4",
    "@tiptap/extension-floating-menu": "3.22.4",
    "@tiptap/extensions": "3.22.4",
    "@tiptap/pm": "3.22.4"
  }
}
